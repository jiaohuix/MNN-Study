<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#FFF6FA">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:title="语音输入" />

    <TextView
        android:id="@+id/tv_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:padding="8dp"
        android:text="初始化中…"/>

    <EditText
        android:id="@+id/et_model_dir"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="ASR 模型目录 (含 config.json)"
        android:text="/sdcard/Download/MoeAvatar/asr/sherpa-mnn-streaming-zipformer-bilingual-zh-en-2023-02-20"
        android:textSize="12sp"
        android:layout_marginTop="8dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_load"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="加载 ASR 模型"
        android:layout_marginTop="8dp"
        app:cornerRadius="16dp"/>

    <TextView
        android:id="@+id/tv_text"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="12dp"
        android:textSize="18sp"
        android:background="#FFFFFF"
        android:layout_marginTop="12dp"
        android:gravity="top|start"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_mic"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="按住说话"
            app:cornerRadius="24dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_send_to_chat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="送到聊天"
            android:layout_marginStart="8dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:cornerRadius="24dp"/>
    </LinearLayout>
</LinearLayout>
